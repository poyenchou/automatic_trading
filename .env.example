# Alpaca API (get keys from https://alpaca.markets → Paper Trading → API Keys)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_TRADING_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# Safety: must be true; bot refuses to run if false
PAPER_TRADING=true

# Screener
NUM_MOVERS=5
EXCHANGE=NYSE

# Strategy parameters
RSI_PERIOD=14
RSI_OVERSOLD=30.0
RSI_OVERBOUGHT=70.0
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
VOLUME_SPIKE_MULTIPLIER=2.0

# Risk management
TAKE_PROFIT_PCT=2.0
STOP_LOSS_PCT=1.0
MAX_POSITION_SIZE_USD=1000.0

# Operational
POLL_INTERVAL_SECONDS=30
LOG_LEVEL=INFO
LOG_FORMAT=json
